{
    "name": "antharuu/phyx",
    "description": "A modern PHP library that rethinks native functions around a more coherent, readable, and predictable API.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/antharuu/Phyx",
    "authors": [
        {
            "name": "Antharuu",
            "homepage": "https://github.com/antharuu"
        }
    ],
    "keywords": [
        "php",
        "standard-library",
        "helpers",
        "native-functions",
        "developer-experience",
        "predictable-api"
    ],
    "support": {
        "issues": "https://github.com/antharuu/Phyx/issues",
        "source": "https://github.com/antharuu/Phyx",
        "docs": "https://github.com/antharuu/Phyx/tree/main/docs"
    },
    "require": {
        "php": "^8.1",
        "ext-intl": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "files": [
            "polyfills/json_validate.php"
        ],
        "psr-4": {
            "Phyx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phyx\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "coverage": "php vendor/bin/phpunit --coverage-text --coverage-html=coverage/html --coverage-clover=coverage/clover.xml",
        "coverage:check": [
            "@coverage",
            "php tools/coverage-check.php"
        ],
        "check": [
            "@test",
            "@analyse",
            "@coverage:check"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
