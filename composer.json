{
    "name": "antharuu/phyx",
    "description": "A modern PHP library that rethinks native functions around a more coherent, readable, and predictable API.",
    "version": "0.1.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Antharuu"
        }
    ],
    "keywords": [
        "php",
        "standard-library",
        "helpers",
        "native-functions",
        "developer-experience",
        "predictable-api"
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Phyx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phyx\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "check": [
            "@test",
            "@analyse"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
