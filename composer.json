{
    "name": "antharuu/phyx",
    "description": "A modern PHP library that rethinks native functions around a more coherent, readable, and predictable API.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Antharuu"
        }
    ],
    "keywords": [
        "php",
        "standard-library",
        "helpers",
        "native-functions",
        "developer-experience",
        "predictable-api"
    ],
    "require": {
        "php": "^8.1",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Phyx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phyx\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "coverage": "/usr/bin/php8.3 vendor/bin/phpunit --coverage-text --coverage-html=coverage/html --coverage-clover=coverage/clover.xml",
        "coverage:check": [
            "@coverage",
            "/usr/bin/php8.3 tools/coverage-check.php"
        ],
        "check": [
            "@test",
            "@analyse",
            "@coverage:check"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
